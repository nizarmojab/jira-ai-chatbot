# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your.email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SCRUM
JIRA_ACCOUNT_ID=your_account_id_here
HARMAN_ACCOUNT_ID=optional_account_id
MARELLI_ACCOUNT_ID=optional_account_id

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Optional settings
LOG_LEVEL=INFO
MAX_RESULTS=25
MEMORY_TURNS=10
DRY_RUN=false
